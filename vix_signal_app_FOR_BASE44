def _parse_pct(s):
    return pd.to_numeric(s.astype(str).str.rstrip("%").str.replace(",",""),
                         errors="coerce") / 100.0

def _parse_price(s):
    return pd.to_numeric(s.astype(str).str.replace(",",""), errors="coerce")


def _load_csv_investing_ohlc(path: str) -> pd.DataFrame:
    """Investing.com style CSV with Date, Price, Open, High, Low columns."""
    df = pd.read_csv(path, encoding="utf-8-sig")
    df.columns = [c.strip().strip('"') for c in df.columns]
    df["DATE"] = pd.to_datetime(df["Date"], format="%m/%d/%Y", errors="coerce")
    df["Open"]  = _parse_price(df["Open"])
    df["High"]  = _parse_price(df["High"])
    df["Low"]   = _parse_price(df["Low"])
    df["Close"] = _parse_price(df["Price"])
    return df.dropna(subset=["DATE","Close"])[["DATE","Open","High","Low","Close"]] \
             .sort_values("DATE")


def _load_csv_vix_history(path: str) -> pd.DataFrame:
    """Special VIX_History.csv format: DATE,OPEN,HIGH,LOW,CLOSE (no quotes)."""
    df = pd.read_csv(path)
    df["DATE"] = pd.to_datetime(df["DATE"], format="%m/%d/%Y")
    return df.rename(columns={"OPEN":"Open","HIGH":"High",
                              "LOW":"Low","CLOSE":"Close"})[
        ["DATE","Open","High","Low","Close"]].sort_values("DATE")


def _load_csv_close_only(path: str) -> pd.DataFrame:
    """Investing.com CSV used as a CLOSE-only series (for VIX3M/VVIX)."""
    df = _load_csv_investing_ohlc(path)
    return df[["DATE","Close"]]


def _load_yfinance(symbol: str, start="1990-01-01") -> pd.DataFrame:
    import yfinance as yf
    d = yf.download(symbol, start=start, progress=False, auto_adjust=True)
    if isinstance(d.columns, pd.MultiIndex):
        d.columns = d.columns.get_level_values(0)
    d = d.reset_index().rename(columns={"Date":"DATE"})
    return d[["DATE","Open","High","Low","Close"]]


def _load_twelvedata(symbol: str, api_key: str,
                     start="1990-01-01") -> pd.DataFrame:
    """Twelve Data REST API — https://twelvedata.com"""
    import requests
    url = ("https://api.twelvedata.com/time_series"
           f"?symbol={symbol}&interval=1day&start_date={start}"
           f"&apikey={api_key}&format=JSON&outputsize=5000")
    r = requests.get(url, timeout=20)
    r.raise_for_status()
    js = r.json()
    if "values" not in js:
        raise RuntimeError(f"Twelve Data error for {symbol}: {js}")
    df = pd.DataFrame(js["values"])
    df["DATE"] = pd.to_datetime(df["datetime"])
    for col in ["open","high","low","close"]:
        df[col] = pd.to_numeric(df[col], errors="coerce")
    return df.rename(columns={"open":"Open","high":"High",
                              "low":"Low","close":"Close"})[
        ["DATE","Open","High","Low","Close"]].sort_values("DATE")


def load_market_data(sources: Dict[str, Dict[str, Any]]) -> pd.DataFrame:
    """
    sources example for production (Twelve Data):
        {
            "vix":   {"kind":"twelvedata","symbol":"VIX",  "api_key": KEY},
            "spx":   {"kind":"twelvedata","symbol":"SPX",  "api_key": KEY},
            "vix3m": {"kind":"twelvedata","symbol":"VIX3M","api_key": KEY},
            "vvix":  {"kind":"twelvedata","symbol":"VVIX", "api_key": KEY},
            # putcall optional; CSV upload supported, API rare
        }

    sources example for dev (yfinance):
        {
            "vix":   {"kind":"yfinance","symbol":"^VIX"},
            "spx":   {"kind":"yfinance","symbol":"^GSPC"},
            "vix3m": {"kind":"yfinance","symbol":"^VIX3M"},
            "vvix":  {"kind":"yfinance","symbol":"^VVIX"},
        }
    """
    def _fetch(spec, kind_label=""):
        if spec["kind"] == "yfinance":
            return _load_yfinance(spec["symbol"])
        if spec["kind"] == "twelvedata":
            return _load_twelvedata(spec["symbol"], spec["api_key"])
        if spec["kind"] == "csv":
            # The 'role' field tells us which CSV format to expect.
            role = spec.get("role", kind_label)
            if role == "vix_history":
                return _load_csv_vix_history(spec["path"])
            if role == "investing_ohlc":
                return _load_csv_investing_ohlc(spec["path"])
            if role == "close_only":
                # Return a frame with placeholder OHLC so downstream code works
                close = _load_csv_close_only(spec["path"])
                close["Open"] = close["Close"]; close["High"] = close["Close"]
                close["Low"] = close["Close"]
                return close[["DATE","Open","High","Low","Close"]]
            raise ValueError(f"Unknown CSV role: {role}")
        raise ValueError(f"Unknown source kind: {spec['kind']}")

    def _ohlc_to(df, prefix):
        return df.rename(columns={
            "Open": f"{prefix}_OPEN", "High": f"{prefix}_HIGH",
            "Low":  f"{prefix}_LOW",  "Close": prefix
        })

    vix   = _ohlc_to(_fetch(sources["vix"],   "vix_history"),     "VIX")
    spx   = _ohlc_to(_fetch(sources["spx"],   "investing_ohlc"),  "SPX")
    vix3m = _fetch(sources["vix3m"], "close_only")[["DATE","Close"]].rename(columns={"Close":"VIX3M"})
    vvix  = _fetch(sources["vvix"],  "close_only")[["DATE","Close"]].rename(columns={"Close":"VVIX"})

    pc_spec = sources.get("putcall")
    if pc_spec and pc_spec["kind"] == "csv":
        pc = pd.read_csv(pc_spec["path"])
        pc["DATE"] = pd.to_datetime(pc["Date"], errors="coerce")
        pc = pc.rename(columns={"Value":"PCRATIO"}).dropna(subset=["DATE","PCRATIO"])
        pc = pc[["DATE","PCRATIO"]].sort_values("DATE")
    else:
        pc = pd.DataFrame({"DATE": vix["DATE"], "PCRATIO": np.nan})

    df = (vix.merge(spx,   on="DATE", how="inner")
              .merge(vix3m, on="DATE", how="left")
              .merge(vvix,  on="DATE", how="left")
              .merge(pc,    on="DATE", how="left")
              .sort_values("DATE").reset_index(drop=True))
    return df


# ─────────────────────────────────────────────────────────────────────────────
# 4.  MODEL FIT + PREDICT
# ─────────────────────────────────────────────────────────────────────────────

def train_models(df_feat: pd.DataFrame, random_state: int = 42):
    df = df_feat.copy()
    df["log_ret_next"] = np.log(df["VIX"].shift(-1) / df["VIX"])
    has_req = df[CORE_REQUIRED].notna().all(axis=1)
    has_tgt = df["target"].notna() & df["log_ret_next"].notna()
    train_df = df[has_req & has_tgt]

    clf = xgb.XGBClassifier(
        n_estimators=150, max_depth=4, learning_rate=0.05,
        subsample=0.8, colsample_bytree=0.8, min_child_weight=5,
        eval_metric="logloss", verbosity=0, random_state=random_state)
    clf.fit(train_df[FEATURES_V3], train_df["target"])

    qreg = xgb.XGBRegressor(
        n_estimators=200, max_depth=4, learning_rate=0.05,
        subsample=0.8, colsample_bytree=0.8, min_child_weight=5,
        objective="reg:quantileerror", quantile_alpha=QUANTILES,
        verbosity=0, random_state=random_state)
    qreg.fit(train_df[FEATURES_V3], train_df["log_ret_next"])
    return clf, qreg, len(train_df)


def _action(prob_up: float, p50: float, rule: dict) -> str:
    if prob_up >= rule["up_p"] and p50 >=  rule["up_m"]: return "LONG_UVIX"
    if prob_up <= rule["dn_p"] and p50 <= -rule["dn_m"]: return "LONG_SVIX"
    return "CASH"


def predict_today(clf, qreg, df_feat: pd.DataFrame) -> Dict[str, Any]:
    has_req = df_feat[CORE_REQUIRED].notna().all(axis=1) & df_feat["VIX"].notna()
    if not has_req.any():
        raise RuntimeError("No row with all required features.")
    last_idx = df_feat.index[has_req].max()
    row = df_feat.loc[last_idx]

    x = row[FEATURES_V3].values.reshape(1, -1)
    prob_up = float(clf.predict_proba(x)[0, 1])
    q = qreg.predict(x)
    if q.ndim == 1 and len(q) == 3:
        q = q.reshape(1, -1)
    p10, p50, p90 = float(q[0, 0]), float(q[0, 1]), float(q[0, 2])

    return {
        "data_through":   row["DATE"].strftime("%Y-%m-%d"),
        "vix":            float(row["VIX"]),
        "spx":            float(row["SPX"]),
        "vix3m":          float(row["VIX3M"]) if pd.notna(row.get("VIX3M", np.nan)) else None,
        "vvix":           float(row["VVIX"])  if pd.notna(row.get("VVIX",  np.nan)) else None,
        "pcratio":        float(row["PCRATIO"]) if pd.notna(row.get("PCRATIO", np.nan)) else None,
        "term_structure": "backwardation" if (pd.notna(row.get("VIX3M", np.nan))
                                              and row["VIX"] > row["VIX3M"]) else "contango",
        "prob_up":        round(prob_up, 4),
        "p10_logret":     round(p10, 5),
        "p50_logret":     round(p50, 5),
        "p90_logret":     round(p90, 5),
        "width":          round(p90 - p10, 5),
        "expected_pct":   round((np.exp(p50) - 1) * 100, 2),
        "p10_pct":        round((np.exp(p10) - 1) * 100, 2),
        "p90_pct":        round((np.exp(p90) - 1) * 100, 2),
        "action_strict":  _action(prob_up, p50, STRICT_RULE),
        "action_loose":   _action(prob_up, p50, LOOSE_RULE),
        "computed_at":    datetime.utcnow().isoformat(timespec="seconds") + "Z",
    }


# ─────────────────────────────────────────────────────────────────────────────
# 5.  PUBLIC ENTRY POINTS  (call one of these from your daily cron job)
# ─────────────────────────────────────────────────────────────────────────────

def compute_signal(sources: Dict[str, Dict[str, Any]]) -> Dict[str, Any]:
    """Generic. Pass any sources dict (mix-and-match providers allowed)."""
    df = load_market_data(sources)
    df_feat = build_features(df)
    clf, qreg, n_train = train_models(df_feat)
    sig = predict_today(clf, qreg, df_feat)
    sig["n_training_rows"] = n_train
    return sig


def get_signal_live(twelvedata_api_key: str,
                    putcall_csv: Optional[str] = None) -> Dict[str, Any]:
    """Production: fetch live data via Twelve Data."""
    sources = {
        "vix":   {"kind":"twelvedata", "symbol":"VIX",   "api_key": twelvedata_api_key},
        "spx":   {"kind":"twelvedata", "symbol":"SPX",   "api_key": twelvedata_api_key},
        "vix3m": {"kind":"twelvedata", "symbol":"VIX3M", "api_key": twelvedata_api_key},
        "vvix":  {"kind":"twelvedata", "symbol":"VVIX",  "api_key": twelvedata_api_key},
    }
    if putcall_csv:
        sources["putcall"] = {"kind":"csv", "path": putcall_csv}
    return compute_signal(sources)


def get_signal_yfinance() -> Dict[str, Any]:
    """Free fallback (yfinance, can be unreliable). Useful for dev."""
    sources = {
        "vix":   {"kind":"yfinance", "symbol":"^VIX"},
        "spx":   {"kind":"yfinance", "symbol":"^GSPC"},
        "vix3m": {"kind":"yfinance", "symbol":"^VIX3M"},
        "vvix":  {"kind":"yfinance", "symbol":"^VVIX"},
    }
    return compute_signal(sources)


def get_signal_csv(vix_csv: str, spx_csv: str, vix3m_csv: str, vvix_csv: str,
