def format_signal(sig: Dict[str, Any]) -> str:
    badge = {"LONG_UVIX":"🔴 LONG UVIX",
             "LONG_SVIX":"🟢 LONG SVIX",
             "CASH":"⚪ CASH"}
    L = []
    L.append("=" * 60)
    L.append(f"  VIX MARKET-TIMING SIGNAL")
    L.append("=" * 60)
    L.append(f"  Data through    : {sig['data_through']}")
    L.append(f"  VIX             : {sig['vix']:.2f}")
    if sig.get("vix3m"):
        L.append(f"  VIX3M           : {sig['vix3m']:.2f}  ({sig['term_structure']})")
    if sig.get("vvix"):
        L.append(f"  VVIX            : {sig['vvix']:.2f}")
    L.append(f"  SPX             : {sig['spx']:.2f}")
    L.append("")
    L.append(f"  Forecast (next trading day VIX move):")
    L.append(f"    P(VIX up)     : {sig['prob_up']*100:.1f}%")
    L.append(f"    Expected      : {sig['expected_pct']:+.2f}%")
    L.append(f"    Range 10-90%  : {sig['p10_pct']:+.2f}%  to  {sig['p90_pct']:+.2f}%")
    L.append("")
    L.append(f"  ACTION (do this at today's close, hold until next flip):")
    L.append(f"    STRICT        : {badge[sig['action_strict']]}")
    L.append(f"    LOOSER        : {badge[sig['action_loose']]}")
    return "\n".join(L)


